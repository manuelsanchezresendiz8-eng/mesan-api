import xml.etree.ElementTree as ET


def analizar_cfdi(xml_string: str) -> dict:
    try:
        root = ET.fromstring(xml_string)
    except ET.ParseError:
        return {"error": "XML invalido"}

    # Namespaces SAT
    ns = {
        "cfdi": "http://www.sat.gob.mx/cfd/4",
        "cfdi3": "http://www.sat.gob.mx/cfd/3"
    }

    total = root.attrib.get("Total", 0)
    rfc_emisor = root.attrib.get("RfcEmisor", "")
    rfc_receptor = root.attrib.get("RfcReceptor", "")

    # Intentar con namespace v4
    emisor = root.find("cfdi:Emisor", ns)
    receptor = root.find("cfdi:Receptor", ns)

    if emisor is None:
        emisor = root.find("cfdi3:Emisor", ns)
    if receptor is None:
        receptor = root.find("cfdi3:Receptor", ns)

    if emisor is not None:
        rfc_emisor = emisor.attrib.get("Rfc", rfc_emisor)
    if receptor is not None:
        rfc_receptor = receptor.attrib.get("Rfc", rfc_receptor)

    conceptos = []
    for c in root.iter("{http://www.sat.gob.mx/cfd/4}Concepto"):
        conceptos.append({
            "descripcion": c.attrib.get("Descripcion"),
            "importe": c.attrib.get("Importe")
        })

    if not conceptos:
        for c in root.iter("{http://www.sat.gob.mx/cfd/3}Concepto"):
            conceptos.append({
                "descripcion": c.attrib.get("Descripcion"),
                "importe": c.attrib.get("Importe")
            })

    return {
        "total": float(total) if total else 0,
        "emisor": rfc_emisor,
        "receptor": rfc_receptor,
        "conceptos": conceptos,
        "num_conceptos": len(conceptos)
    }
